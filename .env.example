# Junto environment — copy to `.env` (git-ignored) and fill in.
# One file serves both the web app (via Vite envDir) and the DB tooling.

# ── Supabase ────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
# Public (safe to expose to the browser):
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-only. SUPABASE_URL mirrors PUBLIC_SUPABASE_URL; the service-role key
# bypasses RLS — never expose it to the browser. Used by the seed script and,
# from Phase 6, the MCP Worker.
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# ── Database (Drizzle / postgres.js) ────────────────────────────────────────
# Dashboard → Project Settings → Database → Connection string.
#  - App on Cloudflare: use the transaction pooler (port 6543).
#  - Local migrate/seed: the direct connection (port 5432) also works.
# Remember to URL-encode special characters in the password.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# ── Seed (optional) ─────────────────────────────────────────────────────────
# Email for the pre-auth default user the seed script creates.
DEFAULT_USER_EMAIL="you@junto.local"
