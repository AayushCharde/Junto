{
  "name": "junto",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @junto/web dev",
    "build": "pnpm --filter @junto/web build",
    "preview": "pnpm --filter @junto/web preview",
    "mcp:dev": "pnpm --filter @junto/mcp dev",
    "mcp:deploy": "pnpm --filter @junto/mcp deploy",
    "check": "pnpm -r check",
    "db:generate": "pnpm --filter @junto/db generate",
    "db:migrate": "pnpm --filter @junto/db migrate",
    "db:push": "pnpm --filter @junto/db push",
    "db:seed": "pnpm --filter @junto/db seed",
    "db:embed": "pnpm --filter @junto/db embed",
    "db:studio": "pnpm --filter @junto/db studio"
  }
}
